PORT=3000
NODE_ENV=development

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector Store — set to "chroma" or "pgvector"
VECTOR_STORE=pgvector

# ChromaDB Configuration
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=pdf-documents

# pgvector Configuration (used when VECTOR_STORE=pgvector)
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DB=sheltertech
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=mypassword
PGVECTOR_TABLE=service_snapshots

